{
  "name": "@trex/storage",
  "version": "0.1.0",
  "description": "Supabase Storage feasibility test",
  "trex": {
    "functions": {
      "env": {
        "_shared": {
          "DATABASE_URL": "${DATABASE_URL}",
          "STORAGE_BACKEND": "file",
          "FILE_STORAGE_BACKEND_PATH": "/tmp/storage",
          "FILE_SIZE_LIMIT": "52428800",
          "IS_MULTITENANT": "false",
          "ANON_KEY": "${BETTER_AUTH_SECRET}",
          "SERVICE_KEY": "${BETTER_AUTH_SECRET}",
          "REGION": "local",
          "GLOBAL_S3_BUCKET": "local",
          "PGRST_JWT_SECRET": "${BETTER_AUTH_SECRET}",
          "AUTH_JWT_SECRET": "${BETTER_AUTH_SECRET}",
          "AUTH_JWT_ALGORITHM": "HS256",
          "ENABLE_IMAGE_TRANSFORMATION": "false",
          "PG_QUEUE_ENABLE": "false",
          "HOME": "/tmp",
          "STORAGE_INSTALL_ROLES": "true"
        }
      },
      "api": [
        {
          "source": "/storage-api",
          "function": "/supabase-storage/functions",
          "imports": "/supabase-storage/deno.json",
          "allowHostFsAccess": true
        }
      ]
    }
  }
}
