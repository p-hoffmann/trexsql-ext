{
  "name": "@data2evidence/d2e-notebook-plugin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "trex": {
    "ui": {
      "routes": [
        {
          "source": "/resources/notebook",
          "target": "/resources/notebook"
        }
      ],
      "uiplugins": {
        "researcher": [
          {
            "enabled": true,
            "type": "app",
            "featureFlag": "notebook",
            "name": "Notebooks",
            "nameI18nKey": "UI_PLUGIN_NOTEBOOKS",
            "pluginPath": "/resources/notebook/lifecycles.js",
            "requiredRoles": [
              "RESEARCHER"
            ],
            "route": "notebook",
            "data": {
              "uiFilesUrl": "https://$$FQDN$$/"
            }
          }
        ]
      }
    }
  },
  "dependencies": {
    "@nlux/react": "^2.17.1",
    "@nlux/themes": "^2.17.1",
    "axios": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "single-spa-react": "^6.0.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  }
}
